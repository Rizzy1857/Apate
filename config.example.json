{
  "_comment": "Example configuration for Mirage / Chronos. Copy to config.json and adjust as needed. All inference runs locally via Ollama — no cloud API keys required.",
  "database": {
    "host": "localhost",
    "port": 5432,
    "name": "chronos",
    "user": "chronos"
  },
  "inference": {
    "ollama_host": "ollama",
    "default_model": "llama3:8b",
    "max_tokens": 800,
    "temperature": 0.7,
    "quota_per_session_per_minute": 20
  },
  "gateway": {
    "ssh_port": 2222,
    "http_port": 8080,
    "max_connections_per_ip": 100,
    "rate_limit_window_seconds": 3600
  },
  "ubuntu_profile": "config/ubuntu.yaml",
  "generation_policy": "config/generation_policy.yaml",
  "logging": {
    "level": "INFO",
    "format": "%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    "file_path": "./logs/chronos.log",
    "max_file_size": "10MB",
    "backup_count": 5,
    "enable_json_logs": false
  },
  "security": {
    "enable_ip_anonymization": true,
    "enable_data_retention_limits": true,
    "data_retention_days": 90,
    "enable_encryption_at_rest": false
  }
}
